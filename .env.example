# Database
DATABASE_URL=postgres://agent_roster:agent_roster@localhost:5432/agent_roster

# Auth
AUTH_SECRET=replace-with-random-secret
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Downloads
DOWNLOAD_URL_SECRET=replace-with-random-secret

# Run provider
RUN_PROVIDER=daytona
DAYTONA_API_KEY=replace-me
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=
DAYTONA_SNAPSHOT=daytona-medium
DAYTONA_ENV_SANDBOX_PATH=.env.sandbox
OPENCLAW_PORT=18789
OPENCLAW_TEMPLATE_DIR=openclaw_config_test
OPENCLAW_PACKAGE=openclaw@latest
OPENAI_RUN_MODEL=gpt-5
RUNTIME_PROVISIONING_TIMEOUT_MINUTES=15
RUN_AUTO_STOP_MINUTES=20
RUN_AUTO_DELETE_MINUTES=0
RUN_AUTO_ARCHIVE_MINUTES=
RUN_IDLE_TIMEOUT_MINUTES=20
RUN_MAX_SESSION_TTL_MINUTES=120
RUN_CLEANUP_GRACE_MINUTES=5
WARM_STANDBY_AUTO_STOP_MINUTES=45
WARM_STANDBY_AUTO_ARCHIVE_MINUTES=180
WARM_STANDBY_IDLE_TIMEOUT_MINUTES=45
WARM_STANDBY_MAX_SESSION_TTL_MINUTES=360
WARM_STANDBY_CLEANUP_GRACE_MINUTES=10
ALWAYS_ON_SAFETY_AUTO_STOP_MINUTES=
ALWAYS_ON_HEARTBEAT_MISSING_MINUTES=15
ALWAYS_ON_UNHEALTHY_PROVIDER_TIMEOUT_MINUTES=10
RUNTIME_MAINTENANCE_BATCH_SIZE=25
RUNTIME_MAINTENANCE_STALE_MINUTES=5
RUNTIME_MAINTENANCE_INTERVAL_SECONDS=60
RUNTIME_MAINTENANCE_BASE_URL=http://localhost:3000
RUNTIME_MAINTENANCE_HTTP_TIMEOUT_SECONDS=30

# Preview chat
OPENAI_API_KEY=replace-me
OPENAI_PREVIEW_MODEL=gpt-4o

# Telegram
TELEGRAM_SECRET_SEED=replace-with-random-secret
TELEGRAM_WEBHOOK_URL=http://localhost:3000/api/webhooks/telegram

# Internal
INTERNAL_API_TOKEN=replace-with-random-token
